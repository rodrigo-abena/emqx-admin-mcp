# EMQX Admin MCP — environment configuration
# Copy to .env and fill in your values.
# Never commit .env to version control.

# Test environment
EMQX_TEST_URL=https://mqtt-admin-test.aquatime.abena.com
EMQX_TEST_API_KEY=your-test-api-key
EMQX_TEST_API_SECRET=your-test-api-secret

# Production environment
EMQX_PROD_URL=https://mqtt-admin.aquatime.abena.com
EMQX_PROD_API_KEY=your-prod-api-key
EMQX_PROD_API_SECRET=your-prod-api-secret
