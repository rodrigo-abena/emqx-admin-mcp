{
  "name": "emqx-admin-mcp",
  "version": "0.1.0",
  "description": "MCP server for EMQX broker administration — cluster status, client management, ACL, tracing, banned clients, metrics",
  "main": "dist/index.js",
  "bin": {
    "emqx-admin-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "emqx",
    "mqtt",
    "mcp",
    "model-context-protocol",
    "iot"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.17",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
